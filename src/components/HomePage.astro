---
import { NavigationIsland } from '@/components/react/islands/NavigationIsland'
import { HeroIsland } from '@/components/react/islands/HeroIsland'
import { BookingFormIsland } from '@/components/react/islands/BookingFormIsland'
import { FleetIsland } from '@/components/react/islands/FleetIsland'
import { ServicesIsland } from '@/components/react/islands/ServicesIsland'
import { AboutIsland } from '@/components/react/islands/AboutIsland'
import { TestimonialsIsland } from '@/components/react/islands/TestimonialsIsland'
import { FAQIsland } from '@/components/react/islands/FAQIsland'
import { FooterIsland } from '@/components/react/islands/FooterIsland'
import { WhatsAppFloatIsland } from '@/components/react/islands/WhatsAppFloatIsland'
import { ScrollToTopIsland } from '@/components/react/islands/ScrollToTopIsland'

interface Props {
    lang: 'en' | 'el'
}

const { lang } = Astro.props
const skipToBooking = lang === 'el' ? 'Μετάβαση στη φόρμα κράτησης' : 'Skip to booking form'
const skipToMain = lang === 'el' ? 'Μετάβαση στο κύριο περιεχόμενο' : 'Skip to main content'
---

<div class="relative min-h-screen bg-background scroll-smooth">
  <!-- Skip links for accessibility -->
  <a
    href="#booking"
    class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-[100] focus:bg-accent focus:text-accent-foreground focus:px-4 focus:py-2 focus:rounded-md focus:outline-none focus:ring-2 focus:ring-accent focus:ring-offset-2"
  >
    {skipToBooking}
  </a>
  <a
    href="#main-content"
    class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-40 focus:z-[100] focus:bg-accent focus:text-accent-foreground focus:px-4 focus:py-2 focus:rounded-md focus:outline-none focus:ring-2 focus:ring-accent focus:ring-offset-2"
  >
    {skipToMain}
  </a>

  <!-- Above the fold hydrates immediately; everything below hydrates when it
       approaches the viewport, so initial-load JS work stays small. -->
  <NavigationIsland client:load lang={lang} />
  <HeroIsland client:load lang={lang} />

  <main id="main-content" role="main">
    <BookingFormIsland client:visible={{ rootMargin: '200px' }} lang={lang} />
    <FleetIsland client:visible={{ rootMargin: '200px' }} lang={lang} />
    <ServicesIsland client:visible={{ rootMargin: '200px' }} lang={lang} />
    <AboutIsland client:visible={{ rootMargin: '200px' }} lang={lang} />
    <TestimonialsIsland client:visible={{ rootMargin: '200px' }} lang={lang} />
    <FAQIsland client:visible={{ rootMargin: '200px' }} lang={lang} />
  </main>

  <FooterIsland client:visible={{ rootMargin: '200px' }} lang={lang} />
  <WhatsAppFloatIsland client:idle lang={lang} />
  <ScrollToTopIsland client:idle lang={lang} />
</div>
