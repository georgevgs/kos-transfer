---
interface Props {
    lang: 'en' | 'el'
    heading: string
    updated: string
    altHref: string
}

const { lang, heading, updated, altHref } = Astro.props
const homeHref = lang === 'el' ? '/el/' : '/'
const backLabel = lang === 'el' ? 'Επιστροφή στην αρχική' : 'Back to home'
const altLabel = lang === 'el' ? 'English' : 'Ελληνικά'
const updatedLabel = lang === 'el' ? 'Τελευταία ενημέρωση' : 'Last updated'
---

<div class="min-h-screen bg-background text-foreground">
  <header class="border-b border-border/60 bg-card/50">
    <div class="max-w-3xl mx-auto px-5 sm:px-6 py-4 flex items-center justify-between">
      <a href={homeHref} class="font-semibold tracking-wide text-primary hover:text-accent transition-colors">
        GK Vip Transfer
      </a>
      <a href={altHref} class="text-sm text-muted-foreground hover:text-accent transition-colors">
        {altLabel}
      </a>
    </div>
  </header>

  <main class="max-w-3xl mx-auto px-5 sm:px-6 py-12 sm:py-16">
    <h1 class="text-3xl sm:text-4xl font-bold tracking-tight mb-2">{heading}</h1>
    <p class="text-sm text-muted-foreground mb-10">{updatedLabel}: {updated}</p>

    <div class="legal-content">
      <slot />
    </div>

    <div class="mt-14 pt-6 border-t border-border/60">
      <a href={homeHref} class="text-accent font-medium hover:underline">← {backLabel}</a>
    </div>
  </main>
</div>

<!-- Email addresses are assembled in the browser so they never sit as plain
     text in the HTML, where harvesting bots would pick them up. Without JS a
     human-readable "[at]/[dot]" fallback stays visible. -->
<script is:inline data-astro-rerun>
  document.querySelectorAll('a[data-email-user]').forEach(function (el) {
    var address = el.getAttribute('data-email-user') + '@' + el.getAttribute('data-email-domain');
    el.setAttribute('href', 'mailto:' + address);
    el.textContent = address;
  });
</script>

<style is:global>
  .legal-content h2 {
    font-size: 1.25rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    margin-top: 2.25rem;
    margin-bottom: 0.625rem;
  }
  .legal-content p {
    color: var(--color-muted-foreground);
    line-height: 1.7;
    margin-bottom: 0.875rem;
  }
  .legal-content ul {
    list-style: disc;
    padding-left: 1.5rem;
    color: var(--color-muted-foreground);
    line-height: 1.7;
    margin-bottom: 0.875rem;
  }
  .legal-content li {
    margin-bottom: 0.375rem;
  }
  .legal-content a {
    color: oklch(0.55 0.15 75);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
</style>
